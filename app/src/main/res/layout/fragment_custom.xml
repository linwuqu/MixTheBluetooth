<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:visibility="invisible"
        android:layout_marginStart="15dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@color/orange"
            android:layout_marginLeft="3dp"
            android:layout_marginRight="3dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="@string/fragment_read_data"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/custom_fragment_empty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:layout_marginEnd="10dp"
            android:textColor="@color/skyBlue"
            android:textSize="16sp"
            android:text="@string/pop_window_fragment_6"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingLeft="15dp"
        android:paddingRight="15dp"
        android:paddingTop="5dp"
        android:visibility="invisible"
        android:orientation="horizontal">
        <com.hc.mixthebluetooth.customView.CheckBoxSample
            android:id="@+id/custom_fragment_read_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginRight="3dp"
            android:layout_marginLeft="3dp"
            android:layout_marginTop="1dp"
            android:layout_marginStart="10dp"
            app:color_background="@color/green"
            app:color_border="@color/green"
            app:size="15dp"/>
        <TextView
            android:id="@+id/custom_fragment_read_hex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="@string/fragment_read_data_hex"/>

        <com.hc.mixthebluetooth.customView.CheckBoxSample
            android:id="@+id/custom_fragment_show_read_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginRight="3dp"
            android:layout_marginLeft="3dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="1dp"
            app:color_background="@color/green"
            app:color_border="@color/green"
            app:size="15dp"/>
        <TextView
            android:id="@+id/custom_fragment_show_read_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="@string/fragment_show_read_data"/>

        <com.hc.mixthebluetooth.customView.CheckBoxSample
            android:id="@+id/custom_fragment_newline_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginRight="3dp"
            android:layout_marginLeft="3dp"
            android:layout_marginStart="15dp"
            android:layout_marginTop="1dp"
            app:color_background="@color/green"
            app:color_border="@color/green"
            app:size="15dp"/>
        <TextView
            android:id="@+id/custom_fragment_newline_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:text="@string/pop_window_fragment_8"/>
    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/custom_fragment_recycler"
        android:layout_width="match_parent"
        android:background="@color/recyclerBack"
        android:paddingRight="15dp"
        android:paddingLeft="15dp"
        android:visibility="invisible"
        android:layout_height="0dp"
        android:layout_weight="0">
    </androidx.recyclerview.widget.RecyclerView>
    <LinearLayout
        android:id="@+id/chart_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:orientation="vertical"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <!-- 合并标题和主数据卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_ion_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
           >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/turtle"/>

                <!-- 标题 -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/ion_analysis_title"
                    android:textColor="@android:color/black"
                    android:textSize="20dp"
                    android:textStyle="bold"/>
                <!-- Bluetooth Icon and Device Name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/bluetooth_icon"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="4dp"/>
                    <TextView
                        android:id="@+id/tv_bluetooth_device_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LT2404E28Q"
                        android:textSize="14sp"
                        android:textColor="@color/gray"
                        android:layout_gravity="center_vertical"/>
                </LinearLayout>

                <!-- 主内容（圆环和离子浓度信息） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <!-- 左侧圆环 -->
                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center_vertical">

                        <com.hc.mixthebluetooth.customView.CircleProgressView
                            android:id="@+id/circle_progress"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:backgroundColor="@color/colorPrimaryLight"
                            app:progress="0.7"
                            app:progressColor="@color/colorPrimary"
                            app:unitText="uL"
                            app:unitTextSize="16sp"
                            app:valueText="0.0" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_horizontal|bottom"
                            android:layout_marginBottom="8dp"
                            android:text="@string/sweat_flow_rate"
                            android:textColor="@color/black"
                            android:textSize="14sp"/>
                    </FrameLayout>
                    <!-- 右侧信息 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingLeft="16dp"
                        android:gravity="center_vertical">
                        <!-- 离子浓度信息 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:id="@+id/linearLayoutIonInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_alignParentLeft="true"
                                android:layout_centerVertical="true">
                                <TextView
                                    android:id="@+id/tv_ion_title"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/ion_concentration_label"
                                    android:textSize="14sp"
                                    android:textColor="@color/black"/>
                                <TextView
                                    android:id="@+id/tv_ion_sub"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/unit_mmol_l"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tv_ion_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true"
                                android:text="--"
                                android:textSize="18sp"
                                android:textColor="@color/black"/>
                        </RelativeLayout>

                        <!-- 汗液流速信息 -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <LinearLayout
                                android:id="@+id/linearLayoutSweatFlowInfo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_alignParentLeft="true"
                                android:layout_centerVertical="true">
                                <TextView
                                    android:id="@+id/tv_sweat_flow_speed_label"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/sweat_flow_speed_label"
                                    android:textSize="14sp"
                                    android:textColor="@color/black"/>
                                <TextView
                                    android:id="@+id/tv_sweat_flow_speed_unit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/unit_mm_s"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>
                            <TextView
                                android:id="@+id/tv_sweat_flow_speed_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentRight="true"
                                android:layout_centerVertical="true"
                                android:text="--"
                                android:textSize="18sp"
                                android:textColor="@color/black"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sodium Chart Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="15dp"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:id="@+id/title_sodium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ocp_chart_title"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp">

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chart_sodium"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:id="@+id/sodium_x_axis_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBottom="@id/chart_sodium"
                        android:layout_alignParentRight="true"
                        android:layout_marginRight="5dp"
                        android:layout_marginBottom="-5dp"
                        android:text="@string/time_axis_label"
                        android:textColor="@android:color/black"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- Sodium Summary Data -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    <!-- Max Fluctuation -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tv_sodium_fluctuation_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="最大波\n动幅度"
                            android:textSize="10sp"
                            android:textColor="@color/gray"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_sodium_fluctuation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_mv"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/gray_light"
                        android:layout_marginVertical="4dp"/>
                    <!-- Max -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_sodium_max_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/max_concentration"
                                android:textSize="10sp"
                                android:textColor="@color/gray"/>
                            <TextView
                                android:id="@+id/tv_sodium_max_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="8sp"
                                android:textColor="@color/gray"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_sodium_max"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_mv"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/gray_light"
                        android:layout_marginVertical="4dp"/>
                    <!-- Min -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_sodium_min_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/min_concentration"
                                android:textSize="10sp"
                                android:textColor="@color/gray"/>
                            <TextView
                                android:id="@+id/tv_sodium_min_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="8sp"
                                android:textColor="@color/gray"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_sodium_min"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_mv"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Potassium Chart Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="300dp"
            app:cardCornerRadius="8dp"
        >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/title_potassium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/eis_impedance_title"
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="5dp">

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chart_potassium"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:id="@+id/potassium_x_axis_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignBottom="@id/chart_potassium"
                        android:layout_alignParentRight="true"
                        android:layout_marginRight="5dp"
                        android:layout_marginBottom="-5dp"
                        android:text="@string/time_axis_label"
                        android:textColor="@android:color/black"
                        android:textSize="12sp" />
                </RelativeLayout>

                <!-- Potassium Summary Data -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">
                    <!-- Max Fluctuation -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tv_eis_fluctuation_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="最大波\n动幅度"
                            android:textSize="10sp"
                            android:textColor="@color/gray"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_eis_fluctuation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_pf"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/gray_light"
                        android:layout_marginVertical="4dp"/>
                    <!-- Max -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_eis_max_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/max_impedance"
                                android:textSize="10sp"
                                android:textColor="@color/gray"/>
                            <TextView
                                android:id="@+id/tv_eis_max_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="8sp"
                                android:textColor="@color/gray"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_eis_max"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_pf"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/gray_light"
                        android:layout_marginVertical="4dp"/>
                    <!-- Min -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_eis_min_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/min_impedance"
                                android:textSize="10sp"
                                android:textColor="@color/gray"/>
                            <TextView
                                android:id="@+id/tv_eis_min_time"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="8sp"
                                android:textColor="@color/gray"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView
                                android:id="@+id/tv_eis_min"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="14sp"
                                android:textColor="@color/black"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unit_pf"
                                android:textSize="8sp"
                                android:textColor="@color/gray"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:paddingLeft="10dp"
        android:paddingRight="10dp">

        <com.hc.mixthebluetooth.customView.UnderlineTextView
            android:id="@+id/custom_fragment_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:layout_marginRight="5dp"
            android:layout_marginLeft="5dp"
            android:text="@string/button_group"
            android:textSize="16sp"
